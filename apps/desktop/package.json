{
  "name": "seethenumbers",
  "productName": "SeeTheNumbers",
  "version": "1.0.0",
  "description": "Sistema de Punto de Venta para pequeños negocios",
  "main": "src/main/main.js",
  "author": "SeeTheNumbers",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "dev:with-web": "ELECTRON_START_URL=http://localhost:3000 electron .",
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.seethenumbers.app",
    "productName": "SeeTheNumbers",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "src/main/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/main/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "src/main/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/main/icon.ico",
      "uninstallerIcon": "src/main/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
